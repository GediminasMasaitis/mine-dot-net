<ui:FluentWindow x:Class="MineDotNet.GUI.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:MineDotNet.GUI.Controls"
                 Title="Minesweeper Solver"
                 Width="1360" Height="940"
                 MinWidth="1100" MinHeight="720"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 WindowStartupLocation="Manual"
                 Left="40" Top="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="230" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Minesweeper Solver">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/MineDotNet.GUI;component/assets/mine.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Main content: board | right panel -->
        <Grid Grid.Row="1" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="500" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0" Padding="8"
                     HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <local:MinesweeperBoardHost x:Name="BoardHost"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch" />
            </ui:Card>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="200" />
                </Grid.RowDefinitions>

                <!-- Actions -->
                <ui:Card Grid.Row="0" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Actions" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10" />
                        <UniformGrid Rows="1" Columns="2" Margin="0,0,0,6">
                            <ui:Button x:Name="ShowBtn" Content="Show"
                                       Icon="{ui:SymbolIcon Eye24}"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,4,0" Click="ShowBtn_Click" />
                            <ui:Button x:Name="SolveBtn" Content="Solve"
                                       Icon="{ui:SymbolIcon Lightbulb24}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Margin="4,0,0,0" Click="SolveBtn_Click" />
                        </UniformGrid>
                        <UniformGrid Rows="1" Columns="2">
                            <ui:Button x:Name="SettingsBtn" Content="Settings"
                                       Icon="{ui:SymbolIcon Settings24}"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,4,0" Click="SettingsBtn_Click" />
                            <ui:Button x:Name="BenchmarkBtn" Content="Benchmark"
                                       Icon="{ui:SymbolIcon DataBarHorizontal24}"
                                       HorizontalAlignment="Stretch"
                                       Margin="4,0,0,0" Click="BenchmarkBtn_Click" />
                        </UniformGrid>
                        <CheckBox x:Name="DirectSolverCheck"
                                  Content="Direct P/Invoke (skip UMSI)"
                                  IsChecked="True"
                                  Margin="0,8,0,0"
                                  Checked="DirectSolverCheck_OnChanged"
                                  Unchecked="DirectSolverCheck_OnChanged" />
                    </StackPanel>
                </ui:Card>

                <!-- Board settings + game controls -->
                <ui:Card Grid.Row="1" Margin="0,10,0,0" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Board" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Width" Opacity="0.7" FontSize="12" />
                                <ui:NumberBox x:Name="WidthBox" Value="16" Minimum="1" Maximum="200" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Height" Opacity="0.7" FontSize="12" />
                                <ui:NumberBox x:Name="HeightBox" Value="30" Minimum="1" Maximum="200" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="DensityLabel" Text="Mine density: 20%" Opacity="0.7" FontSize="12" Margin="0,14,0,2" />
                        <Slider x:Name="DensitySlider" Minimum="1" Maximum="99" Value="20"
                                ValueChanged="DensitySlider_OnValueChanged"
                                TickPlacement="None" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="5" />

                        <TextBlock Text="Game" FontWeight="SemiBold" FontSize="13" Margin="0,18,0,10" />
                        <UniformGrid Rows="1" Columns="3">
                            <ui:Button x:Name="ResetBtn" Content="Reset"
                                       HorizontalAlignment="Stretch" Margin="0,0,4,0" Click="ResetBtn_Click" />
                            <ui:Button x:Name="GenerateBtn" Content="Generate"
                                       HorizontalAlignment="Stretch" Margin="4,0,4,0" Click="GenerateBtn_Click" />
                            <ui:Button x:Name="AutoPlayBtn" Content="Auto play"
                                       Appearance="Primary" HorizontalAlignment="Stretch" Margin="4,0,0,0" Click="AutoPlayBtn_Click" />
                        </UniformGrid>
                    </StackPanel>
                </ui:Card>

                <!-- Log -->
                <ui:Card Grid.Row="2" Margin="0,10,0,0" Padding="14"
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="Log" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            <ui:Button x:Name="ClearLogBtn" Content="Clear" HorizontalAlignment="Right"
                                       FontSize="11" Padding="10,3" Click="ClearLogBtn_Click" />
                        </Grid>
                        <Border Grid.Row="1" Margin="0,8,0,0"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <TextBox x:Name="LogBox" IsReadOnly="True"
                                     Background="Transparent" BorderThickness="0"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" AcceptsReturn="True" Padding="6" />
                        </Border>
                    </Grid>
                </ui:Card>
            </Grid>
        </Grid>

        <!-- Bottom: Map/masks (full width) -->
        <ui:Card Grid.Row="2" Margin="16,0,16,16" Padding="12"
                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Map and masks" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" />
                <local:MapMaskEditor Grid.Row="1" x:Name="MapEditor" />
            </Grid>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
