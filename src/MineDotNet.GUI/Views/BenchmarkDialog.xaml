<ui:FluentWindow x:Class="MineDotNet.GUI.Views.BenchmarkDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:MineDotNet.GUI.Controls"
                 xmlns:charts="clr-namespace:MineDotNet.GUI.Controls.Charts"
                 Title="Benchmark"
                 Width="1440" Height="880"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Benchmark" ShowMaximize="False" ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: config -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Board settings -->
                <ui:Card Grid.Row="0" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Board" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10" />

                        <Grid x:Name="FixedBoardPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Width" Opacity="0.7" FontSize="12" />
                                <ui:NumberBox x:Name="WidthBox" Value="30" Minimum="1" Maximum="200" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Height" Opacity="0.7" FontSize="12" />
                                <ui:NumberBox x:Name="HeightBox" Value="16" Minimum="1" Maximum="200" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="DensityLabel" Text="Mine density: 20%" Opacity="0.7" FontSize="12" Margin="0,14,0,2" />
                        <Slider x:Name="DensitySlider" Minimum="1" Maximum="99" Value="20"
                                ValueChanged="DensitySlider_OnValueChanged"
                                TickPlacement="None" IsSnapToTickEnabled="True" SmallChange="1" LargeChange="5" />

                        <TextBlock Text="Sweep" Opacity="0.7" FontSize="12" Margin="0,14,0,2" />
                        <ComboBox x:Name="SweepBox" SelectionChanged="SweepBox_OnSelectionChanged">
                            <ComboBoxItem Content="None" IsSelected="True" />
                            <ComboBoxItem Content="Width" />
                            <ComboBoxItem Content="Height" />
                            <ComboBoxItem Content="Mine density" />
                            <ComboBoxItem Content="Solver parameter" />
                        </ComboBox>

                        <StackPanel x:Name="ParamPanel" Margin="0,10,0,0" Visibility="Collapsed">
                            <TextBlock Text="Parameter" Opacity="0.7" FontSize="12" />
                            <ComboBox x:Name="ParamBox" Margin="0,2,0,0"
                                      SelectionChanged="ParamBox_OnSelectionChanged" />
                        </StackPanel>

                        <Grid x:Name="SweepPanel" Margin="0,10,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock x:Name="SweepFromLabel" Text="From" Opacity="0.7" FontSize="12" />
                                <ui:NumberBox x:Name="SweepFromBox" Value="10" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock x:Name="SweepToLabel" Text="To" Opacity="0.7" FontSize="12" />
                                <ui:NumberBox x:Name="SweepToBox" Value="30" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBlock x:Name="SweepStepLabel" Text="Step" Opacity="0.7" FontSize="12" />
                                <ui:NumberBox x:Name="SweepStepBox" Value="5" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Games per solver" Opacity="0.7" FontSize="12" Margin="0,14,0,2" />
                        <ui:NumberBox x:Name="GamesBox" Value="100" Minimum="1" Maximum="100000" />

                        <CheckBox x:Name="LiveLogCheck" Content="Show UMSI log (slower)" IsChecked="True" Margin="0,14,0,0" />
                        <CheckBox x:Name="DirectSolverCheck" Content="Use direct P/Invoke (skip UMSI)" IsChecked="False" Margin="0,6,0,0" />
                    </StackPanel>
                </ui:Card>

                <!-- Solvers list -->
                <ui:Card Grid.Row="1" Margin="0,10,0,0" Padding="14"
                         VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Solvers to compare" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            <ui:Button x:Name="AddBtn" Content="Add" Icon="{ui:SymbolIcon Add24}"
                                       HorizontalAlignment="Right" Click="AddBtn_Click" />
                        </Grid>
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                            <ListBox x:Name="SolversList"
                                     BorderThickness="0" Background="Transparent"
                                     SelectionChanged="SolversList_OnSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="4,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <ui:Button x:Name="EditBtn" Content="Edit" Icon="{ui:SymbolIcon Edit24}" Margin="0,0,4,0" Click="EditBtn_Click" />
                            <ui:Button x:Name="DeleteBtn" Content="Delete" Icon="{ui:SymbolIcon Delete24}"
                                       Appearance="Danger" Click="DeleteBtn_Click" />
                        </StackPanel>
                    </Grid>
                </ui:Card>
            </Grid>

            <!-- RIGHT: progress (top) + charts (middle) + UMSI log (bottom) -->
            <ui:Card Grid.Column="2" Padding="14"
                     VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" MinHeight="240" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" MinHeight="140" />
                    </Grid.RowDefinitions>

                    <!-- Progress -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Progress" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10" />

                        <StackPanel Grid.Row="1" Margin="0,0,0,10">
                            <Grid>
                                <TextBlock x:Name="ProgressLabel" Text="Not started" FontSize="12" Opacity="0.7" />
                                <TextBlock x:Name="ElapsedLabel" Text="" FontSize="12" Opacity="0.7" HorizontalAlignment="Right" />
                            </Grid>
                            <ProgressBar x:Name="ProgressBar" Height="4" Margin="0,6,0,0" Minimum="0" Maximum="100" Value="0" />
                        </StackPanel>

                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                MaxHeight="160">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ResultsList" Margin="8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding GamesPlayedText}" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
                                                <TextBlock Grid.Column="2" Text="{Binding WinRateText}" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{Binding WinRateBrush}" />
                                                <TextBlock Grid.Column="3" Text="{Binding TallyText}" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
                                                <TextBlock Grid.Column="4" Text="{Binding AvgTimeText}" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
                                                <TextBlock Grid.Column="5" Text="{Binding AvgIterText}" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <!-- Charts: fixed-mode (3 charts) vs sweep-mode (3 charts).
                         Only one Border at a time is Visible; the other stays
                         Collapsed so it consumes no layout space. -->
                    <Border Grid.Row="1" Margin="0,14,0,0" x:Name="FixedChartsPanel"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <UniformGrid Rows="1" Columns="3" Margin="4">
                            <charts:OutcomeBarChart x:Name="OutcomeChart" Margin="4" />
                            <charts:TimeCdfChart x:Name="CdfChart" Margin="4" />
                            <charts:WinRateVsTimeScatter x:Name="ScatterChart" Margin="4" />
                        </UniformGrid>
                    </Border>
                    <Border Grid.Row="1" Margin="0,14,0,0" x:Name="SweepChartsPanel" Visibility="Collapsed"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <UniformGrid Rows="1" Columns="3" Margin="4">
                            <charts:WinRateSweepChart x:Name="WinRateSweepChart" Margin="4" />
                            <charts:AvgTimeSweepChart x:Name="AvgTimeSweepChart" Margin="4" />
                            <charts:AvgIterationsSweepChart x:Name="AvgIterationsSweepChart" Margin="4" />
                        </UniformGrid>
                    </Border>

                    <!-- Log -->
                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="UMSI log" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
                            <ui:Button x:Name="ClearLogBtn" Content="Clear" HorizontalAlignment="Right"
                                       FontSize="11" Padding="10,3" Click="ClearLogBtn_Click" />
                        </Grid>
                        <Border Grid.Row="1"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <TextBox x:Name="LogBox" IsReadOnly="True"
                                     Background="Transparent" BorderThickness="0"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" AcceptsReturn="True" Padding="6" />
                        </Border>
                    </Grid>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- Bottom action bar -->
        <Grid Grid.Row="2" Margin="16,0,16,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="RunBtn" Content="Run benchmark" Icon="{ui:SymbolIcon Play24}"
                           Appearance="Primary" Width="180" Margin="0,0,8,0" Click="RunBtn_Click" />
                <ui:Button x:Name="StopBtn" Content="Stop" Icon="{ui:SymbolIcon Stop24}"
                           Appearance="Caution" Width="120" Margin="0,0,8,0"
                           IsEnabled="False" Click="StopBtn_Click" />
                <ui:Button x:Name="CloseBtn" Content="Close" Width="100" Click="CloseBtn_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
