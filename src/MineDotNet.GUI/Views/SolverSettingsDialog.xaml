<ui:FluentWindow x:Class="MineDotNet.GUI.Views.SolverSettingsDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:MineDotNet.GUI.Controls"
                 Title="Solver settings"
                 Width="720" Height="680"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Solver settings" ShowMaximize="False" ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" FontWeight="SemiBold" />
            <ui:TextBox Grid.Row="0" Grid.Column="1" x:Name="NameBox" Margin="0,4" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Implementation" VerticalAlignment="Center" FontWeight="SemiBold" />
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ImplBox" Margin="0,4"
                      SelectionChanged="ImplBox_OnSelectionChanged" />
        </Grid>

        <Border Grid.Row="2" Margin="16,4,16,8"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <local:ObjectEditor x:Name="Editor" />
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
            <ui:Button x:Name="OkBtn" Content="OK" Appearance="Primary" Width="100" Margin="0,0,8,0" Click="OkBtn_Click" />
            <ui:Button x:Name="CancelBtn" Content="Cancel" Width="100" Click="CancelBtn_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
