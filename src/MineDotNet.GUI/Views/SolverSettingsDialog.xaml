<ui:FluentWindow x:Class="MineDotNet.GUI.Views.SolverSettingsDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:MineDotNet.GUI.Controls"
                 Title="Solver settings"
                 Width="720" Height="680"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Solver settings" ShowMaximize="False" ShowMinimize="False" />

        <Border Grid.Row="1" Margin="16,8,16,8"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <local:ObjectEditor x:Name="Editor" />
        </Border>

        <Grid Grid.Row="2" Margin="16,0,16,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ui:Button x:Name="SaveBtn" Content="Save..." Icon="{ui:SymbolIcon Save24}"
                           Margin="0,0,4,0" Click="SaveBtn_Click" />
                <ui:Button x:Name="LoadBtn" Content="Load..." Icon="{ui:SymbolIcon FolderOpen24}"
                           Click="LoadBtn_Click" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="OkBtn" Content="OK" Appearance="Primary" Width="100" Margin="0,0,8,0" Click="OkBtn_Click" />
                <ui:Button x:Name="CancelBtn" Content="Cancel" Width="100" Click="CancelBtn_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
