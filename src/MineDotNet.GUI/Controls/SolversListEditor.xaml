<UserControl x:Class="MineDotNet.GUI.Controls.SolversListEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
            <ListBox x:Name="List"
                     BorderThickness="0"
                     Background="Transparent"
                     SelectionChanged="List_OnSelectionChanged"
                     FontFamily="Segoe UI"
                     FontSize="13">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Display}"
                                       VerticalAlignment="Center"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0" Width="140">
            <ui:Button x:Name="AddBtn" Content="Add" Icon="{ui:SymbolIcon Add24}" HorizontalAlignment="Stretch" Margin="0,0,0,4" Click="AddBtn_Click" />
            <ui:Button x:Name="EditBtn" Content="Edit" Icon="{ui:SymbolIcon Edit24}" HorizontalAlignment="Stretch" Margin="0,0,0,4" Click="EditBtn_Click" />
            <ui:Button x:Name="DeleteBtn" Content="Delete" Appearance="Danger" Icon="{ui:SymbolIcon Delete24}" HorizontalAlignment="Stretch" Margin="0,0,0,12" Click="DeleteBtn_Click" />
            <ui:Button x:Name="UpBtn" Content="Move up" Icon="{ui:SymbolIcon ArrowUp24}" HorizontalAlignment="Stretch" Margin="0,0,0,4" Click="UpBtn_Click" />
            <ui:Button x:Name="DownBtn" Content="Move down" Icon="{ui:SymbolIcon ArrowDown24}" HorizontalAlignment="Stretch" Margin="0,0,0,4" Click="DownBtn_Click" />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <ui:Button x:Name="SaveBtn" Content="Save..." Icon="{ui:SymbolIcon Save24}" Margin="0,0,4,0" Click="SaveBtn_Click" />
            <ui:Button x:Name="LoadBtn" Content="Load..." Icon="{ui:SymbolIcon FolderOpen24}" Click="LoadBtn_Click" />
        </StackPanel>
    </Grid>
</UserControl>
